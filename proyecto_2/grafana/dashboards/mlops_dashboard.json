      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(predict_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 (Worst)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(predict_latency_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(predict_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 (Median)",
          "refId": "C"
        }
      ],
      "title": "Latency Analysis (SLA Monitoring)",
      "type": "timeseries"
    },
